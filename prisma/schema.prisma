// StudioONE — Prisma schema (Phase 2: full content model, CLAUDE.md §5).
//
// A typed singleton JSON document (SiteSettings.content) holds all scalar copy,
// validated by a zod schema on read/write (lib/content.ts). Reorderable lists
// get their own tables with an `order` column. Booking/Block/RecurringHold/
// AdminUser tables land now; their behaviour is wired in Phases 4–5.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Scalar copy + all settings, one row, `content` shape validated by zod.
model SiteSettings {
  id            Int      @id @default(1)
  content       Json // hero, manifesto, room statement, chapter labels, CTA, footer, meta…
  // operational settings:
  openHour      Int      @default(7)
  closeHour     Int      @default(22)
  minHours      Int      @default(1)
  maxHours      Int      @default(8)
  resetHours    Int      @default(1)
  daysAhead     Int      @default(28)
  pendingTtlHrs Int      @default(48)
  bacs          Json // accountName, sortCode, accountNo, referencePrefix, demoFlag
  doorCode      String // current active code
  doorCodeNote  String?
  studioEmails  String[] // booking-alert recipients
  fromEmail     String   @default("hello@studioone.room")
  contact       Json // email, phone, "replies within the hour"
  map           Json // lat, lng, zoom, tagLabel, coordsText, openMapsUrl, embedSrc
  // Testing mode: snapshot current content/lists/blocks/holds on enter; on exit
  // restore them and delete bookings created during the test window.
  testMode      Boolean  @default(false)
  testStartedAt DateTime?
  testSnapshot  Json?
  updatedAt     DateTime @updatedAt
}

// Reorderable lists — each row has `order`; admin can add/remove/drag.
model Kind {
  id      String @id @default(cuid())
  order   Int
  kicker  String
  line    String
  timeTag String
}

model HowStep {
  id      String @id @default(cuid())
  order   Int
  label   String
  heading String
  body    String
}

model Policy {
  id     String @id @default(cuid())
  order  Int
  kicker String
  body   String
}

model RoomFact {
  id     String @id @default(cuid())
  order  Int
  strong String
  text   String
}

model ChangeoverItem {
  id    String @id @default(cuid())
  order Int
  text  String
}

model NavItem {
  id     String  @id @default(cuid())
  order  Int
  label  String
  anchor String
  cur    String? // cursor label (data-cur), e.g. "Read"
}

model FooterColumn {
  id    String @id @default(cuid())
  order Int
  title String
  links Json // [{ label, href }]
}

model HeroEyebrow {
  id    String @id @default(cuid())
  order Int
  text  String
}

model ManifestoFoot {
  id    String @id @default(cuid())
  order Int
  term  String
  def   String
}

// Drives the diary + the rates strip.
model RateTier {
  id    String @id @default(cuid())
  hours Int    @unique
  price Int
}

model MediaAsset {
  id        String   @id @default(cuid())
  key       String
  url       String
  alt       String?
  createdAt DateTime @default(now())
}

// Photos of the building/room — a reorderable list rendered in the room band.
model RoomPhoto {
  id    String @id @default(cuid())
  order Int
  url   String
  alt   String @default("")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  EXPIRED
}

model Booking {
  id          String        @id @default(cuid())
  name        String
  email       String
  date        DateTime // the booked day (date-only, London)
  startHour   Int // e.g. 14 (24h, London)
  endHour     Int // exclusive end, e.g. 16
  hours       Int
  pricePence  Int
  reference   String        @unique
  status      BookingStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  confirmedAt DateTime?
  cancelledAt DateTime?
  codeSentAt  DateTime?

  @@index([date, status])
}

model Block {
  id        String   @id @default(cuid())
  date      DateTime
  startHour Int
  endHour   Int
  label     String?
}

model RecurringHold {
  id        String  @id @default(cuid())
  weekday   Int // 0=Mon … 6=Sun
  startHour Int
  endHour   Int
  label     String?
}

// The owner (seeded from ADMIN_EMAIL) has full access. Sub-admins are created
// from the Team page and are scoped to bookings + opening hours (lib/admin/
// permissions.ts). Role gates every admin page and mutation server-side.
enum Role {
  OWNER
  SUBADMIN
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         Role     @default(OWNER)
  createdAt    DateTime @default(now())
}
