# ─────────────────────────────────────────────────────────────────────────────
# StudioONE environment variables. Copy to .env and fill in. NEVER commit .env.
# (.env* is git-ignored.)
# ─────────────────────────────────────────────────────────────────────────────

# Postgres connection string (Railway provides this as a service variable).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# Secret used to sign the admin session cookie (iron-session). Generate with:
#   openssl rand -base64 32
SESSION_SECRET=

# Seeded owner login. ADMIN_PASSWORD is read only by the seed script, which
# stores a bcrypt hash; unset it afterwards. (Used from Phase 3 onward.)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Resend transactional email (used from Phase 4 onward).
RESEND_API_KEY=
EMAIL_FROM=hello@studioone.room
# Comma-separated booking-alert recipients.
STUDIO_ALERT_EMAILS=

# S3-compatible object store for image uploads — Cloudflare R2 recommended
# (used from Phase 3 onward). Documented fallback: a Railway persistent volume.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# Public site URL (used for canonical/OG links and admin deep links).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# All availability / "today" / open-hours logic runs in Europe/London.
TZ=Europe/London
