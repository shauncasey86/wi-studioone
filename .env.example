# ─────────────────────────────────────────────────────────────────────────────
# StudioONE environment variables. Copy to .env and fill in. NEVER commit .env.
# (.env* is git-ignored.)
# ─────────────────────────────────────────────────────────────────────────────

# Postgres connection string (Railway provides this as a service variable).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# Secret used to sign the admin session cookie (iron-session). Generate with:
#   openssl rand -base64 32
SESSION_SECRET=

# Seeded owner login. ADMIN_PASSWORD is read only by the seed script, which
# stores a bcrypt hash; unset it afterwards. (Used from Phase 3 onward.)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Resend transactional email. Both are swappable any time (change the Railway
# variable + redeploy). EMAIL_FROM must be a verified sender on whichever Resend
# account RESEND_API_KEY belongs to — when borrowing a test account from another
# project, use that account's verified domain (or onboarding@resend.dev for quick
# tests). Without RESEND_API_KEY, emails are logged instead of sent.
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev
# Comma-separated booking-alert recipients.
STUDIO_ALERT_EMAILS=

# Image storage. The active backend is the filesystem/volume store at UPLOAD_DIR
# (served by /api/media/...). On Railway, mount a persistent volume here so
# uploads survive deploys. Defaults to ./uploads.
UPLOAD_DIR=uploads
# S3-compatible object store for image uploads — Cloudflare R2 recommended
# (recommended production backend; slots in behind lib/storage). Documented
# fallback is the UPLOAD_DIR volume above.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# Public site URL (canonical/OG links + admin deep links). No custom domain yet —
# use the Railway URL (e.g. https://wi-studioone.up.railway.app). Swap for the
# custom domain once it's added.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# All availability / "today" / open-hours logic runs in Europe/London.
TZ=Europe/London
